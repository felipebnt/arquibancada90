// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model Jersey {
  id          String   @id @default(cuid())
  name        String
  club        String
  season      String
  category    String   // "Lançamentos", "Times Nacionais", "Times Europeus"
  type        String   // "Home", "Away", "Third", "Treino", "Goleiro"
  price       Float?   // Price in BRL
  composition String?  // Material composition
  technology  String?  // Fabric technology
  imageFront  String?  // URL to front image
  imageBack   String?  // URL to back image
  imageDetail String?  // URL to detail/close-up image
  isFeatured  Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([club])
  @@index([isFeatured])
}

model WaitlistEntry {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
}
